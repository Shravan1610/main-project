# ═══════════════════════════════════════════
# GreenTrust Frontend — Environment Variables
# ═══════════════════════════════════════════
# Copy to .env.local and fill in values

NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# --- Supabase Market Data (required for market charting/detail pages) ---
# Get these from Supabase Dashboard → Project Settings → API
# Use the frontend-safe publishable/anon key here, never the service_role key
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_SUPABASE_MARKET_SYNC_FUNCTION=market-data-sync-v2

# Google Maps API key (required for Street View)
# Get one at https://console.cloud.google.com/apis/credentials
# Enable "Maps JavaScript API" and "Street View Static API"
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# --- VAPI Voice Agent (Web Calls) ---
# Public key only — never put the private key here
# Found at: https://dashboard.vapi.ai/account → API Keys
NEXT_PUBLIC_VAPI_PUBLIC_KEY=
# Assistant ID to use for web calls
# Found at: https://dashboard.vapi.ai/assistants → your assistant → ID
NEXT_PUBLIC_VAPI_ASSISTANT_ID=

# --- Blockchain / Integrity Ledger ---
NEXT_PUBLIC_RPC_URL=
NEXT_PUBLIC_CONTRACT_ADDRESS=
# Current client code references this directly. Treat it as unsafe and prefer server-side signing.
NEXT_PUBLIC_PRIVATE_KEY=

# --- Next.js API Route Server Credentials ---
PRIVATE_KEY=
CONTRACT_ADDRESS=
