{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MapLayersResponse",
  "description": "Response from GET /layers",
  "type": "object",
  "required": ["exchanges", "climateEvents", "newsLocations"],
  "properties": {
    "exchanges": {
      "type": "array",
      "description": "Major stock exchanges with coordinates",
      "items": {
        "type": "object",
        "required": ["id", "name", "coordinates"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "country": { "type": "string" },
          "coordinates": {
            "type": "object",
            "required": ["lat", "lng"],
            "properties": {
              "lat": { "type": "number" },
              "lng": { "type": "number" }
            }
          },
          "marketStatus": { "type": ["string", "null"], "enum": ["open", "closed", "pre-market", "after-hours", null] }
        }
      }
    },
    "climateEvents": {
      "type": "array",
      "description": "Active climate/weather events",
      "items": {
        "type": "object",
        "required": ["id", "type", "severity", "coordinates"],
        "properties": {
          "id": { "type": "string" },
          "type": { "type": "string" },
          "severity": { "type": "string", "enum": ["minor", "moderate", "severe", "extreme"] },
          "location": { "type": "string" },
          "description": { "type": ["string", "null"] },
          "coordinates": {
            "type": "object",
            "required": ["lat", "lng"],
            "properties": {
              "lat": { "type": "number" },
              "lng": { "type": "number" }
            }
          },
          "date": { "type": ["string", "null"], "format": "date-time" }
        }
      }
    },
    "newsLocations": {
      "type": "array",
      "description": "Geocoded news article locations",
      "items": {
        "type": "object",
        "required": ["id", "title", "coordinates"],
        "properties": {
          "id": { "type": "string" },
          "title": { "type": "string" },
          "source": { "type": "string" },
          "category": {
            "type": ["string", "null"],
            "enum": ["risk", "opportunity", "regulation", "disaster", "general", null]
          },
          "coordinates": {
            "type": "object",
            "required": ["lat", "lng"],
            "properties": {
              "lat": { "type": "number" },
              "lng": { "type": "number" }
            }
          },
          "url": { "type": ["string", "null"] }
        }
      }
    }
  }
}