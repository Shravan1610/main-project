{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "MapLayersResponse",
  "description": "Response from GET /layers",
  "type": "object",
  "required": ["exchanges", "climate", "news", "updatedAt"],
  "properties": {
    "exchanges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "label", "coordinates"],
        "properties": {
          "id": { "type": "string" },
          "kind": { "type": "string", "enum": ["exchange"] },
          "label": { "type": "string" },
          "coordinates": {
            "type": "object",
            "required": ["lat", "lng"],
            "properties": {
              "lat": { "type": "number" },
              "lng": { "type": "number" }
            }
          }
        }
      }
    },
    "climate": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "label", "coordinates"],
        "properties": {
          "id": { "type": "string" },
          "kind": { "type": "string", "enum": ["climate"] },
          "label": { "type": "string" },
          "coordinates": {
            "type": "object",
            "required": ["lat", "lng"],
            "properties": {
              "lat": { "type": "number" },
              "lng": { "type": "number" }
            }
          }
        }
      }
    },
    "news": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "kind", "label", "coordinates"],
        "properties": {
          "id": { "type": "string" },
          "kind": { "type": "string", "enum": ["news"] },
          "label": { "type": "string" },
          "category": { "type": ["string", "null"] },
          "coordinates": {
            "type": "object",
            "required": ["lat", "lng"],
            "properties": {
              "lat": { "type": "number" },
              "lng": { "type": "number" }
            }
          }
        }
      }
    },
    "updatedAt": { "type": "string", "format": "date-time" }
  }
}
