{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "AnalyzeResponse",
  "description": "Response from GET /analyze?entity={id}",
  "type": "object",
  "required": ["id", "name", "type", "coordinates", "market", "news", "climate", "scores", "drivers", "newsSignals", "researchBrief", "coverage"],
  "properties": {
    "id": { "type": "string" },
    "name": { "type": "string" },
    "type": { "type": "string", "enum": ["company", "stock", "crypto"] },
    "ticker": { "type": ["string", "null"] },
    "country": { "type": ["string", "null"] },
    "exchange": { "type": ["string", "null"] },
    "coordinates": {
      "type": "object",
      "required": ["lat", "lng"],
      "properties": {
        "lat": { "type": "number" },
        "lng": { "type": "number" }
      }
    },
    "market": {
      "type": "object",
      "required": ["price", "changePercent", "currency"],
      "properties": {
        "price": { "type": "number" },
        "changePercent": { "type": "number" },
        "currency": { "type": "string" },
        "exchange": { "type": ["string", "null"] },
        "marketCap": { "type": ["number", "null"] },
        "volume": { "type": ["number", "null"] },
        "high52w": { "type": ["number", "null"] },
        "low52w": { "type": ["number", "null"] }
      }
    },
    "news": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "source", "publishedAt", "url"],
        "properties": {
          "title": { "type": "string" },
          "summary": { "type": ["string", "null"] },
          "source": { "type": "string" },
          "publishedAt": { "type": "string", "format": "date-time" },
          "url": { "type": "string", "format": "uri" },
          "category": {
            "type": ["string", "null"],
            "enum": ["risk", "opportunity", "regulation", "disaster", "earnings", "macro", "supply-chain", "general", null]
          },
          "coordinates": {
            "type": ["object", "null"],
            "properties": {
              "lat": { "type": "number" },
              "lng": { "type": "number" }
            }
          }
        }
      }
    },
    "climate": {
      "type": "object",
      "required": ["summary", "events", "vulnerability"],
      "properties": {
        "summary": { "type": "string" },
        "vulnerability": {
          "type": "string",
          "enum": ["low", "moderate", "high", "critical"]
        },
        "events": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["type", "severity", "location"],
            "properties": {
              "type": { "type": "string" },
              "severity": { "type": "string", "enum": ["minor", "moderate", "severe", "extreme"] },
              "location": { "type": "string" },
              "description": { "type": ["string", "null"] }
            }
          }
        }
      }
    },
    "scores": {
      "type": "object",
      "required": ["sustainability", "financialRisk", "longTermImpact"],
      "properties": {
        "sustainability": { "type": "number", "minimum": 0, "maximum": 100 },
        "financialRisk": { "type": "number", "minimum": 0, "maximum": 100 },
        "longTermImpact": { "type": "number", "minimum": 0, "maximum": 100 }
      }
    },
    "drivers": {
      "type": "object",
      "required": ["sustainability", "financialRisk", "longTermImpact"],
      "properties": {
        "sustainability": { "type": "array", "items": { "type": "object", "required": ["label", "impact"], "properties": { "label": { "type": "string" }, "impact": { "type": "string", "enum": ["positive", "negative", "neutral"] }, "weight": { "type": ["number", "null"] }, "detail": { "type": ["string", "null"] } } } },
        "financialRisk": { "type": "array", "items": { "type": "object", "required": ["label", "impact"], "properties": { "label": { "type": "string" }, "impact": { "type": "string", "enum": ["positive", "negative", "neutral"] }, "weight": { "type": ["number", "null"] }, "detail": { "type": ["string", "null"] } } } },
        "longTermImpact": { "type": "array", "items": { "type": "object", "required": ["label", "impact"], "properties": { "label": { "type": "string" }, "impact": { "type": "string", "enum": ["positive", "negative", "neutral"] }, "weight": { "type": ["number", "null"] }, "detail": { "type": ["string", "null"] } } } }
      }
    },
    "newsSignals": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["category", "count", "direction"],
        "properties": {
          "category": { "type": "string" },
          "count": { "type": "integer", "minimum": 0 },
          "direction": { "type": "string", "enum": ["positive", "negative"] },
          "headline": { "type": ["string", "null"] }
        }
      }
    },
    "researchBrief": { "$ref": "brief-response.json" },
    "coverage": {
      "type": "object",
      "required": ["articleCount", "sourceCount", "lastUpdated"],
      "properties": {
        "articleCount": { "type": "integer", "minimum": 0 },
        "sourceCount": { "type": "integer", "minimum": 0 },
        "lastUpdated": { "type": "string", "format": "date-time" },
        "latestPublishedAt": { "type": ["string", "null"], "format": "date-time" }
      }
    }
  }
}
