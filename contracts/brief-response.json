{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "BriefResponse",
  "description": "Response from GET /brief?entity={id}",
  "type": "object",
  "required": ["entityId", "summary", "keyPoints", "risks", "opportunities", "confidence", "sourceRefs", "generatedAt"],
  "properties": {
    "entityId": { "type": "string" },
    "summary": { "type": "string" },
    "keyPoints": {
      "type": "array",
      "items": { "type": "string" }
    },
    "risks": {
      "type": "array",
      "items": { "type": "string" }
    },
    "opportunities": {
      "type": "array",
      "items": { "type": "string" }
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "sourceRefs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "source", "url"],
        "properties": {
          "title": { "type": "string" },
          "source": { "type": "string" },
          "url": { "type": "string" }
        }
      }
    },
    "generatedAt": { "type": ["string", "null"], "format": "date-time" }
  }
}
