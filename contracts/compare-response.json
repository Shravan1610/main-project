{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "CompareResponse",
  "description": "Response from POST /compare with up to 3 entities",
  "type": "object",
  "required": ["entities"],
  "properties": {
    "entities": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "items": {
        "$ref": "analyze-response.json",
        "description": "Each entity follows the full AnalyzeResponse schema"
      }
    },
    "comparisonSummary": {
      "type": ["object", "null"],
      "description": "Optional high-level comparison insights",
      "properties": {
        "bestSustainability": { "type": "string" },
        "lowestRisk": { "type": "string" },
        "bestLongTerm": { "type": "string" }
      }
    }
  }
}