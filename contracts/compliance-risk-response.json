{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ComplianceRiskResponse",
  "description": "Response from the Compliance Risk & Recommendation Engine endpoint",
  "type": "object",
  "required": [
    "severity_score",
    "risk_level",
    "frameworks_checked",
    "risk_flags",
    "consistency_issues",
    "action_items",
    "total_risk_flags",
    "high_severity_count",
    "medium_severity_count",
    "low_severity_count"
  ],
  "properties": {
    "severity_score": {
      "type": "number",
      "minimum": 0,
      "maximum": 100
    },
    "risk_level": {
      "type": "string",
      "enum": ["low", "medium", "high", "critical"]
    },
    "frameworks_checked": {
      "type": "array",
      "items": { "type": "string" }
    },
    "risk_flags": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "severity", "section", "description", "recommendation"],
        "properties": {
          "id": { "type": "string" },
          "severity": { "type": "string", "enum": ["high", "medium", "low"] },
          "section": { "type": "string" },
          "description": { "type": "string" },
          "original_text": { "type": "string" },
          "recommendation": { "type": "string" }
        }
      }
    },
    "consistency_issues": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["description", "severity"],
        "properties": {
          "description": { "type": "string" },
          "sections_involved": {
            "type": "array",
            "items": { "type": "string" }
          },
          "severity": { "type": "string", "enum": ["high", "medium", "low"] }
        }
      }
    },
    "action_items": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["priority", "action", "section", "rationale"],
        "properties": {
          "priority": { "type": "integer", "minimum": 1, "maximum": 5 },
          "action": { "type": "string" },
          "section": { "type": "string" },
          "rationale": { "type": "string" }
        }
      }
    },
    "total_risk_flags": { "type": "integer" },
    "high_severity_count": { "type": "integer" },
    "medium_severity_count": { "type": "integer" },
    "low_severity_count": { "type": "integer" }
  }
}
