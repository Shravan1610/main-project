# ═══════════════════════════════════════════
# GreenTrust — Root Environment Variables
# ═══════════════════════════════════════════
# Copy this file to .env and fill in your values
# Never commit .env to git

# --- Backend ---
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:3000

# --- External API Keys ---
MARKET_API_KEY=          # Alpha Vantage or Yahoo Finance
NEWS_API_KEY=            # NewsAPI.org or GNews
CLIMATE_API_KEY=         # OpenWeatherMap or NOAA
GEOCODING_API_KEY=       # OpenCage or leave empty for Nominatim (free)

# --- ESG Model ---
ESG_MODEL_URL=           # Render-hosted ESG model endpoint

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_MAP_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png
