# ═══════════════════════════════════════════
# GreenTrust Backend — Environment Variables
# ═══════════════════════════════════════════
# Copy to .env and fill in values

PORT=8000
CORS_ORIGINS=http://localhost:3000
DEBUG=true
# Alpha Vantage market data key (used for stock lookup and quote endpoints)
EODHD_API_KEY=
# Optional legacy alias if you want to keep the old name
MARKET_API_KEY=
FINNHUB_API_KEY=
COINGECKO_DEMO_API_KEY=
NEWS_API_KEY=
GNEWS_API_KEY=
THE_NEWS_API_KEY=
GOOGLE_AI_STUDIO_API_KEY=
GEMINI_MODEL=gemini-3.1-flash-lite-preview
CLIMATE_API_KEY=
GEOCODING_API_KEY=
YOUTUBE_API_KEY=

# --- VAPI Voice Agent (Phone Calls) ---
# Private/server key — used to authenticate outbound phone calls via REST API
# Found at: https://dashboard.vapi.ai/account → API Keys → Private Key
VAPI_API_KEY=
# Assistant ID to attach to the outbound phone call
# Found at: https://dashboard.vapi.ai/assistants → your assistant → ID
VAPI_ASSISTANT_ID=
# Phone number ID to dial from (must be purchased/provisioned in VAPI dashboard)
# Found at: https://dashboard.vapi.ai/phone-numbers → your number → ID
VAPI_PHONE_NUMBER_ID=

# --- ESG Model ---
ESG_MODEL_URL=
NLP_MODEL_URL=

# --- Supabase Edge Function Proxy ---
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DOCUMENT_ANALYZER_EDGE_FUNCTION_NAME=document-analyzer-v2

# --- Document Analyzer Scraping ---
PLAYWRIGHT_HEADLESS=true
PLAYWRIGHT_ENABLED=false
LOG_LEVEL=INFO
REQUEST_TIMEOUT_SECONDS=12
CACHE_TTL_SECONDS=300
